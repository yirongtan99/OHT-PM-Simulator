############################################
#Version of file
############################################
FILE VERSION,1
DATA,0,DEF File,"3.02"
END
############################################
#Add function at Ver2.5
############################################
EXTENTION V2.5,1
DATA,0,
	1	,#available of 485 function(0:Unavailable, 1:Available)
	16	,#Maximum supported COM port.
	1	,#Algorithm on Print out(0:Old, 1:New)
	0	,#Warning at model parameter is not exist(0:No warning, 1:Warning)
	0	,#Warning at default parameter is not exist(0:No warning, 1:Warning)
END
############################################
#Setting of serial port
############################################
COM PORT,1
DATA,0
	1		,#Port number
	9600	,#Baud rate
#Timeout setting (This setting is changed by each model at start software)
	500		,#Timeout 1
	10000	,#Timeout 2
	2		,#Retry times
#Timeout setting at axis scanning (This setting is changed by each model at start software)
	500		,#Timeout 1
	10000	,#Timeout 2
	2		,#Retry times
#Timeout setting at model scanning (This setting is changed by each model at start software)
	500		,#Timeout 1
	10000	,#Timeout 2
	2		,#Retry times
#Timeout setting at finishing auto-tuning(This setting is changed by each model at start software)
	500		,#Timeout 1
	10000	,#Timeout 2
	1		,#Retry times
END
############################################
#DLL version to use
############################################
DLL VERSION,1
DATA,	0
	3	,#Version of PTM.DLL
	2	,#Version of FFT.DLL(Not use in PtmBL)
END
############################################
#Setting of Encoder(not use in PtmBL)
############################################
DEF ENCODER,20
#You can define encoder code and functions to 50 items.
#If there's no correspond encoder in this list, Panaterm uses first type(no.0x0000).
#Num,	#Code,#Name,#Bits,#Pulses/Rot,#Type(Abs:1, Inc:0),#Status function(0:Disable, 1:Enable)
DATA,	0,0x0000,---------------,17,131072,1,1
DATA,	1,0x0002,11 bit absolute,11,2048,1,1
DATA,	2,0x1103,17 bit absolute,17,131072,1,1
DATA,	3,0x1203,17 bit incremental,17,131072,0,0
DATA,	4,0x2103,17 bit absolute,17,131072,1,1
DATA,	5,0x2203,17 bit absolute,17,131072,1,1
DATA,	6,0x1303,@test 1,8,256,0,0
DATA,	7,0x1403,@test 2,9,512,0,0
DATA,	8,0x1503,@test 3,10,1024,0,0
DATA,	9,0x1503,@test 4,11,2048,0,0
END
############################################
#Warning messages
############################################
ALART,1
DATA,0	,#Message on FFT measuring(Not use in PtmBL)
	Caution
	Load moves back and forth under the measurement.It must be measured under condition you can stop the measurement anytime,just in case.
	0
DATA,1	,#Message on auto-tuning(Not use in PtmBL)
	Caution
	Load moves back and forth under the auto tuning.It must be measured under condition you can stop the measurement anytime,just in case.
	0
DATA,2  ,#Message on reset abusolute encoder(Not use in PtmBL)
	Caution
	Multi-turn data is reset to "0" with execution.Do not keep this condition in order to avoid an accident,due to a motor goes back to an index phase quickly Reset the mechanical index after clearing absolute data.
	0
DATA,3  ,#Message on selecting disable axis(Not use)
	Caution
	Selected axis was not confirmed its connection.There could be an unexpected error, an unusual display or unusual Panaterm status, if you selected an invalid axis number.Connection can be confirmed by re-scanning.
	1
DATA,4  ,#Message on waveform graphic(Not use)
	Caution
	Measures wave form graphic.It must be measured under condition you can stop the measurement anytime,just in case.
	1
DATA,5  ,#Message on resonance measuring
	Caution in the resonance point measure
	It is recommended to measure the machine resonance point with gain as low as possible.("Position loop gain" and "Velocity loop gain" should be lower "Velocity loop integration time constant" should be higher)
	1
END
