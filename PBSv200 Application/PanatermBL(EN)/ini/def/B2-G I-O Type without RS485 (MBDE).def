############################################
#Absolute encoder status bit
############################################
ABSO MENU,15
DATA,0,Over speed, -
DATA,1,Full absolute encoder, -
DATA,2,Counter error, -
DATA,3,Counter over flow, -
DATA,4,-,-
DATA,5,Multi turn error, -
DATA,6,Battery error, -
DATA,7,Battery alarm,-
DATA,8,-,-
DATA,9,-,-
DATA,10,-,-
DATA,11,-,-
DATA,12,Battery error, -
DATA,13,Error, -
DATA,14,-,-
DATA,15,-,-
END
