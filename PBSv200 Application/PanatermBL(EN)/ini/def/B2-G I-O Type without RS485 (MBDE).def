############################################
#Positioning combobox setting
############################################
POSITIONING COMBO,32
#Velocity
DATA,0x00,0,"V1",0,"Comment for V1"
DATA,0x01,0,"V2",1,"Comment for V2"
DATA,0x02,0,"V3",2,"Comment for V3"
DATA,0x03,0,"V4",3,"Comment for V4"
DATA,0x04,0,"V5",4,"Comment for V5"
DATA,0x05,0,"V6",5,"Comment for V6"
DATA,0x06,0,"V7",6,"Comment for V7"
DATA,0x07,0,"V8",7,"Comment for V8"
DATA,0x08,0,"V9",8,"Comment for V9"
DATA,0x09,0,"V10",9,"Comment for V10"
DATA,0x0A,0,"V11",10,"Comment for V11"
DATA,0x0B,0,"V12",11,"Comment for V12"
DATA,0x0C,0,"V13",12,"Comment for V13"
DATA,0x0D,0,"V14",13,"Comment for V14"
DATA,0x0E,0,"V15",14,"Comment for V15"
DATA,0x0F,0,"V16",15,"Comment for V16"
#Acceration
DATA,0x00,1,"A1",0,"Comment for A1"
DATA,0x01,1,"A2",1,"Comment for A2"
DATA,0x02,1,"A3",2,"Comment for A3"
DATA,0x03,1,"A4",3,"Comment for A4"
#Deceleration
DATA,0x00,2,"D1",0,"Comment for D1"
DATA,0x01,2,"D2",1,"Comment for D2"
DATA,0x02,2,"D3",2,"Comment for D3"
DATA,0x03,2,"D4",3,"Comment for D4"
#Mode
DATA,0x00,3,"Incremental",0,"Comment for incremental"
DATA,0x01,3,"Absolute",1,"Comment for absolute"
DATA,0x02,3,"Rotary",2,"Comment for rotary"
DATA,0x03,3,"Dowel time",3,"Comment dowel time"
#Block
DATA,0x00,4,"Single",0,"Comment for single"
DATA,0x01,4,"Block",1,"Comment for block"
#S-shaped Acceleration
DATA,0x00,7,"SACC1",0,"Comment for s-shape acc 1"
DATA,0x01,7,"SACC2",1,"Comment for s-shape acc 2"
DATA,0x02,7,"SACC3",2,"Comment for s-shape acc 3"
DATA,0x03,7,"SACC4",3,"Comment for s-shape acc 4"
#S-shaped deceleration
DATA,0x00,8,"SDEC1",0,"Comment for s-shape dec 1"
DATA,0x01,8,"SDEC2",1,"Comment for s-shape dec 2"
DATA,0x02,8,"SDEC3",2,"Comment for s-shape dec 3"
DATA,0x03,8,"SDEC4",3,"Comment for s-shape dec 4"
