DATA,13,+A Internal vel. cmnd. select 2, -    Internal vel. cmnd. select 2
DATA,14,- ,-
DATA,15,+A Scale error, -    Scale error
DATA,16,- ,-
DATA,17,- ,-
DATA,18,+A Smoothing switching, -    Smoothing switching
