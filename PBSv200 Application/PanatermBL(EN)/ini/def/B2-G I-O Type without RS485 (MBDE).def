############################################
# for MBDE(B2-G) Series Def file(2003-6)
############################################
#Version of this software
############################################
VERSION,1
DATA,0
	0x1017		,#function control(when driver is connected via 232)
	0x1417		,#function control(when driver is connected via 485)
	0x1114		,#function control(when no driver is connects)
#Bit0:Monitor.Bit1:Alarm.Bit2:Parameter.Bit3:Auto tuning
#Bit4:Wave form graphic.Bit5:Frequency characteristics
#Bit6:Positioning Parameter
#Bit7:Positioning Monitor
#Bit8:Model selection.Bit9:Communication control. Bit10:Axis setting. Bit11:Password.Bit12:Port selection
#Bit14:Log window. Bit15:Control window
END
############################################
#Version of the file
############################################
FILE VERSION,1
DATA,1,Series basic file,"1.00.00"
END
############################################
#Extension by Version3.6
############################################
EXTENTION V3.6,1
#Max value of Machine Stiffness at Auto-Tuning Screen.
DATA,1,9
END
############################################
#Extended Function Control for Ver3.5
############################################
EXTENTION V3.5,1
DATA,0
####
#Support Full Closed mode at FFT measurement condition (depending on Amplifier)
#0:Not supported	1:Supported
0,
####
#Default FFT measurement condition for Full closed
#0:Check Off (Motor Speed)
#1:Check On (External Scale Speed)
0,
####
#Use 32bit Paramer or Not (depending on Amplifier)
#0:Not Use	1:Use
0,
####
#The lead of 32bit parameter
0,
####
#The number of 32bit User parameter
0,
####
#The number of 32bit parameter (User + System)
0
END
###################################################
#Change for Panaterm BL (2003-3)
###################################################
############################################
#Measuring item in drop-down-list of CH0 and CH1(2003-3)
############################################
MEASURE ITEM,16
#	Name			DspName		unit		User(0)/Maker(1)
DATA,0,"Actual speed",		"Act spd",		"[r/min]",		0,		# Actual Speed
DATA,1,"Command speed",		"Cmd spd",	"[r/min]",		0,		# Cmd Speed
DATA,2,"Torque",			"Torque",		"[%]",		0,		# Torque
DATA,3,"Internal DC Voltage",			"Voltage",		"[*10V]",	0,		# Internal voltage
DATA,4,"Position error",		"P-Error",		"[pulse]",		1,		# Pos Error
DATA,5,"Angle info",			"Angle",		"[degree]",	1,		# Angle
DATA,6,"CS1",			"CS1",		"[-]",		1,		# CS1
DATA,7,"CS2",			"CS2",		"[-]",		1,		# CS2
DATA,8,"CS3",			"CS3",		"[-]",		1,		# CS3
DATA,9,"Org CS1",			"Org CS1",		"[-]",		1,		# Org-CS1
DATA,10,"Org CS2",			"Org CS2",		"[-]",		1,		# Org-CS2
DATA,11,"Org CS3",			"Org CS3",		"[-]",		1,		# Org-CS3
DATA,12,"ZDT",			"ZDT",		"[-]",		1,		# ZDT
DATA,13,"CSA",			"CSA",		"[-]",		1,		# CSA
DATA,14,"Amp",			"Amp",		"[-]",		1,		# Amp
DATA,15,"Load rate",			"Load",		"[-]",		1,		# Not use
END
############################################
#Comment of drop-down-list(2003-3)(New for BL)
############################################
CHANNEL COMMENT,2
#	Comment
DATA,0,		"Select an item to measure through Channel0.",		#CH0
DATA,1,		"Select an item to measure through Channel1.",		#CH1
END
############################################
#I/O info in wave form graphic(2003-3)(New for BL)
############################################
WAVE BIT,16
#	BitName	Display
DATA,0, 	I1, 	1,
DATA,1, 	I2, 	1,
DATA,2, 	I3, 	1,
DATA,3, 	I4,		0,
DATA,4, 	I5, 	0,
DATA,5, 	I6, 	0,
DATA,6, 	Reserved, 	0,
DATA,7, 	Reserved, 	0,
DATA,8, 	O1, 	1,
DATA,9, 	O2, 	1,
DATA,10, 	Reserved, 	0,
DATA,11, 	Reserved, 	0,
DATA,12, 	Reserved, 	0,
DATA,13, 	Reserved, 	0,
DATA,14, 	Reserved, 	0,
DATA,15, 	Reserved, 	0,
END
############################################
#Extension by Version3.0
############################################
EXTENTION V3.0,1
DATA,0
#####
#Selection of Positioning Function
#1:Use Positioning Monitor and Positioning Parameter
#0:Don't Use Positioning Monitor and Positioning Parameter
0,	
#####
#Select items in Waveform function
#0:OFF
#1:ON
0,
#####
2,	#Maximum measurment items(2003-3)
#####
128,	#Coin Bit(Set by decimal)
#####
0,	#First number of steps
16,	#User step data
16,	#System step data
#####
0,	#Numbers of 16bit positioning parameter
0x38,	#Numbers of 16bit positioning parameter(user)
0x40,	#Numbers of 16bit positioning parameter(system)
#####
0,	#Numbers of 32bit positioning parameter
4,	#Numbers of 32bit positioning parameter(user)
4,	#Numbers of 32bit positioning parameter(system)
#####
-2147483648,	#maximum value at step
2147483647,	#mimimum value at step
#####
"Set the measuring item.",	#Tool-tip text (2003-3)
#####
END
############################################
#Serial port setting(to be reset at model setting)
############################################
COM PORT,1
DATA,0
	1	,#Port No.
	9600	,#Baud rate
#Time out setting at normal communication
	500	,#Time out 1
	10000	,#Time out 2
	2	,#Retry times
#Time out setting at axis scanning
	500	,#Time out 1
	10000	,#Time out 2
	2	,#Retry times
#Time out setting at model scanning(Setting at Default.def can be used in this setting.)
	500	,#Time out 1
	10000	,#Time out 2
	2	,#Retry times
#Time out setting at auto tuning complete scanning(can't be used for MSDA series.)
	500	,#Time out 1
	10000	,#Time out 2
	1	,#Retry times
END
############################################
#Numbers (of such as parameter)
############################################
MAX ITEM,1
DATA,0
	0xff		,#Max. item numbers
	0x80		,#User parameters
	0x80		,#System parameters
	0x80		,#System parameter-starting address
	0xB8		,#Max. parameters to be checked at writing to EEPROM
	32		,#I/O parameters
	14		,#Alarm display items
	14		,#Alarm time display items
	0x5F		,# Heading upper digit of parameter at Intel Hex file
	2048		,#FFT points of default	
	50		,#FFT measurement amplitudes of default
	0		,#FFT measurement offsets of dafault
	1		,#FFT measurement sampling rate of default
 	1000.00	,#Max.display frequency of frequency characteristics graph
	0.001   	,#FFT sampling unit(s)(2003-3)	
	0.001   	,#Wave form graphic sampling unit (s)(2003-3)
	1 ,#Simultaneous measurement of multiple items at wave form graphic(1 for MSDA)
	1		,# Display of control mode
	1		,# Display of 1st. page of I/O
	1		,# Display of 2nd. page of I/O
	1		,# Display of load page
	1		,# Display of absolute page on the screen
	1		,# Display of clear on absolute page
	1		,# Display of the current time
	-5000		,# Lower trigger limit of wave form graphic
	5000		,# Upper trigger limit of wave form graphic
	1 ,# Issuance of command obtaining execution right at writing or measuring
	2		,# Auto tuning command selection0:X 1:Z 2:A
	10		,# Dividing value of torque at display
END
############################################
#Parameter control information
############################################
PARA MENU,255
