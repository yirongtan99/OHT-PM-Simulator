############################################
# Cautions at auto tuning
############################################
"AUTO MESSAGE",7
DATA,0,"1. Motor and load applicable for this auto tuning are limited."
DATA,1,"    Check up the operation manual."
DATA,2,"2. During auto tuning, max. output torque can be set up to that of the "
DATA,3,"    Max.Torque Set-up Parameter, and CW and CCW overtravel inhibit input are disabled."
DATA,4,"3. Driver may enter the oscillation state depending on the load. Pay extra"
DATA,5,"   attention. Once in oscillation, turn to the servo-off immediately,"
DATA,6,"   and return the gain to the original value with the parameter set-up."
DATA,7,"4. Read the operation manual carefully before executing the auto tuning."
#
#Operation
#
DATA,9,"Set the machine stiffness. Click <Execute> button to execute"
#
#Cautions on frequency characteristics measurement
#
DATA,10,"Motor speed varies intensely. Pay extra attention to the safety."
DATA,11,"For the worst case, measure so that you can turn to servo-off immediately."
DATA,12,"If there is a risk of the machine break-down due to extensive motor movement,"
DATA,13,"do not use this function."
DATA,14,"Measure with as low gain as possible."
DATA,15,"Larger offset set-up may make the machine move exceeding the limit. Pay extra attention."
DATA,16,"If you need a help on measurement condition set-up, click the <Help> button."
DATA,17,"Set the measurement condition.  Click the <Execute the measurement>button to start measurement."
DATA,18,""
DATA,19,""
#
#Monitor screen
#
DATA,20,"Check-sum of the external scale feed back is the total pulses which the driver saved since the control power on."
DATA,21,"When the load rate exceeds 100%, trip may occur. Adjust the action pattern so that the rate may not exceed 100%."
DATA,22,"Value of the regenerative load rate is the load of the regenerative discharge resistor, and not the regenerative power."
DATA,23,"Check-sum data of the command pulses is the total command pulses before scaling, which the driver saved since the control power on."
DATA,24,"Check-sum of the feed back pulses is the total amount of the motor(encoder) movement since the control power on. Unit in encoder resolution."
DATA,25,""
DATA,26,""
DATA,27,""
DATA,28,""
DATA,29,""
#
#Parameter screen
#
DATA,30,"You can change the set-up value by pressing the Enter-key or clicking the <Change of the setting value> button, after entering the set-up value."
DATA,31,""
DATA,32,""
DATA,33,""
DATA,34,""
END
############################################
#Color of each line of the graph
############################################
"GRAPH DATA",1
DATA,0
	0		,# Speed
	16711680	,# Torque
	255		,# Error
	16711935	,# Commanded speed
END
############################################
#Control Mode
############################################
CTRL MODE MENU,7		
DATA,0," Position"	
DATA,1,"Speed"		
DATA,2,"Torque"			
DATA,3,"Semi-close"	
DATA,4,"Hybrid"		
DATA,5,"Full close"	
DATA,6,"External encoder"	
END
############################################
#Meaning of the error(which the driver send back) or bit of warning byte
############################################
BIT NAME EXT,0
DATA,0					,#at normal command
	8					,# 8
	"In-sampling, others"		,# bit 0
	"Servo alarm, others"		,# bit 1
	"Torque saturation, Servo-off, others"	,# bit 2
	"No error"				,# bit 3
	"RS485 error"			,# bit 4
	"Command error"			,# bit 5
	"None definition error"		,# bit 6
	"Error bit ON"			,# bit 7
DATA,1					,# at auto tuning
	8					,#8
	"In-sampling, others"		,# bit 0
	"Servo alarm, others"		,# bit 1
	"Servo-off"				,# bit 2
	"No error"				,# bit 3
	"RS485 error"			,# bit 4
	"Command error"			,# bit 5
	"None definition error"		,# bit 6
	"Error bit ON"			,# bit 7
DATA,2					,#at measuring frequency characteristics
	8					,#8
	"In-sampling, others"		,# bit 0
	"Servo alarm, others"		,# bit 1
	"Servo-off"				,# bit 2
	"No error"				,# bit 3
	"RS485 error"			,# bit 4
	"Command error"			,# bit 5
	"None definition error"		,# bit 6
	"Error bit ON"			,# bit 7
DATA,10					,#when warning is displayed on the monitor screen
	16					,#16
	"Battery warning"			,# bit0
	"No-definition"			,# bit1
	"No-definition"			,# bit 2
	"No-definition"			,# bit 3
	"No-definition"			,# bit 4
	"Regeneration warning"		,# bit 5
	"No-definition"			,# bit 6
	"Overload warning"		,# bit 7
	"No-definition"			,# bit 8
	"No-definition"			,# bit 9
	"No-definition"			,# bit 10
	"No-definition"			,# bit 11
	"No-definition"			,# bit 12
	"No-definition"			,# bit 13
	"No-definition"			,# bit 14
	"No-definition"			,# bit 15
END
############################################
#Parameters displayed at auto tuning
############################################
AUTO PARA,7			
#1: display 0: non-display
DATA,0,1, position gain:,0X10
DATA,1,1, velocity gain:,0X11
DATA,2,1, velocity integration time:,0X12
DATA,3,1, speed detection filter:,0X13
DATA,4,1, torque filter time constant:,0X14
DATA,5,1, inertia ratio:,0X20
DATA,6,0, not in use:,0X15
END
############################################
#Control mode which displays the fill close pages
############################################
FULL CLOSE ENABLE MODE,7			
#DATA,#3,#1	,# Full close page displayed at mode 3
DATA,4,1	,# Full close page displayed at mode 4
DATA,5,1	,# Full close page displayed at mode 5
DATA,6,1	,# Full close page displayed at mode 6
END
